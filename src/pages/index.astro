---
import Base from '../layouts/Base.astro';
import { loadData } from '../data/cards.js';
import * as core from '../lib/core.js';

const { cards, banks } = await loadData();
core.configure(cards, banks);
const appHtml = core.renderRoute({ route: 'home' });

const title = 'Card Gyani — Compare credit cards by fees, rewards & lounge access';
const description = `Browse ${cards.length}+ credit cards by what you actually want — fees, rewards, lounge access and forex. No forms, no spam calls.`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Card Gyani',
  description,
  url: Astro.site ? Astro.site.href : undefined,
};
---
<Base {title} {description} {appHtml} {cards} {banks} init={{ route: 'home' }} {jsonLd} />
